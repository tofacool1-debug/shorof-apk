{
  "expo": {
    "name": "Shorof Digital Pro",
    "slug": "shorof-digital",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "jsEngine": "hermes",
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-updates",
        {}
      ]
    ],
    "assetBundlePatterns": [
      "assets/*"
    ],
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.shorof.digital"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.shorof.digital"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "updates": {
      "url": "https://u.expo.dev/de3329e9-ed7a-4005-abfa-7bda2599b5d4"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "eas": {
        "projectId": "de3329e9-ed7a-4005-abfa-7bda2599b5d4"
      }
    }
  }
}
