{
  "expo": {
    "name": "Shorof Digital Pro",
    "slug": "shorof-digital",
    "version": "1.0.0",
    "android": {
      "package": "com.shorof.digital",
      "enableProguardInReleaseBuilds": true,
      "enableShrinkResourcesInReleaseBuilds": true,
      "compileSdkVersion": 35,
      "targetSdkVersion": 35
    }
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "shorof-digital",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.shorof.digital" 
    },
    "android": {
      "package": "com.shorof.digital",
      "backgroundColor": "#ffffff"
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "updates": {
      "url": "https://u.expo.dev/de3329e9-ed7a-4005-abfa-7bda2599b5d4",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "eas": {
        "projectId": "de3329e9-ed7a-4005-abfa-7bda2599b5d4"
      }
    }
  }
}
