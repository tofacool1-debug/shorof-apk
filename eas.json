{
  "cli": {
    "version": ">=16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "production": {
      "android": {
      "buildType": "apk",
        "gradleCommand": ":app:assembleRelease",
        "splits": {
          "abi": true 
        },
      "distribution": "internal",
      "channel": "production",
      "env": {
        "EXPO_USE_FAST_RESOLVER": "1"}
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease",
        "splits": {
          "abi": true 
        }
      }
    }
  },
  "submit": {
    "production": {}
  }
}
}
